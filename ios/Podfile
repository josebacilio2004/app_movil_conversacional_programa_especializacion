# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/FLUTTER_ROOT\=(.*)/)
      return matches[1].strip if matches
    end
  end
  raise "Could not find FLUTTER_ROOT in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  flutter_post_install(installer)

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # ============================================================
      # Fix 1: BoringSSL-GRPC  — Xcode 16 rejects the '-G' flag
      # Fix 2: gRPC-Core       — Xcode 16 rejects missing template <>
      # Instead of patching source files (fragile), we tell the
      # compiler to downgrade these two errors to warnings.
      # ============================================================
      if ['BoringSSL-GRPC', 'gRPC-Core', 'gRPC-C++'].include?(target.name)
        existing = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'
        unless existing.include?('-Wno-error=missing-template-arg-list-after-template-kw')
          config.build_settings['OTHER_CFLAGS'] = "#{existing} -Wno-error=missing-template-arg-list-after-template-kw"
        end

        existing_cpp = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        unless existing_cpp.include?('-Wno-error=missing-template-arg-list-after-template-kw')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{existing_cpp} -Wno-error=missing-template-arg-list-after-template-kw"
        end
      end

      # Remove the unsupported '-G' flag from per-file COMPILER_FLAGS in BoringSSL-GRPC
      if target.name == 'BoringSSL-GRPC'
        target.source_build_phase.files.each do |file|
          if file.settings && file.settings['COMPILER_FLAGS']
            flags = file.settings['COMPILER_FLAGS'].split
            flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' || flag == '-G' }
            file.settings['COMPILER_FLAGS'] = flags.join(' ')
          end
        end
      end
    end
  end
end
