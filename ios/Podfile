# The target runtime and platform for the application
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/FLUTTER_ROOT\=(.*)/)
      return matches[1].strip if matches
    end
  end
  raise "Could not find FLUTTER_ROOT in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  begin
    flutter_post_install(installer)
  rescue => e
    puts "=== ERROR IN FLUTTER POST INSTALL ==="
    puts e.message
    puts e.backtrace.join("\n")
    puts "====================================="
  end
  
  begin
    installer.pods_project.targets.each do |target|
      # Fix for Xcode 16 "unsupported option '-G' for target 'arm64-apple-ios10.0'" error in BoringSSL-GRPC
      if target.name == 'BoringSSL-GRPC'
        target.build_phases.each do |phase|
          if phase.respond_to?(:files)
            phase.files.each do |file|
              if file.settings && file.settings['COMPILER_FLAGS']
                flags = file.settings['COMPILER_FLAGS'].split
                flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' || flag == '-G' }
                file.settings['COMPILER_FLAGS'] = flags.join(' ')
              end
            end
          end
        end
      end
    end
  rescue => e
    puts "=== ERROR IN BORINGSSL FIX ==="
    puts e.message
    puts e.backtrace.join("\n")
    puts "=============================="
  end

  begin
    # Fix for Xcode 16 "A template argument list is expected after a name prefixed by the template keyword" in gRPC-Core
    grpc_file_path = "Pods/gRPC-Core/src/core/lib/promise/detail/basic_seq.h"
    if File.exist?(grpc_file_path)
      file_content = File.read(grpc_file_path)
      problematic_line = 'return Traits::template CallSeqFactory(f_, *cur_, std::move(arg));'
      correct_line = 'return Traits::template CallSeqFactory<>(f_, *cur_, std::move(arg));'
      if file_content.include?(problematic_line)
        puts "=== Patching gRPC-Core basic_seq.h for Xcode 16 compatibility ==="
        file_content.gsub!(problematic_line, correct_line)
        File.open(grpc_file_path, "w") { |file| file.write(file_content) }
      end
    else
      puts "=== Warning: gRPC-Core basic_seq.h file not found at #{grpc_file_path} ==="
    end
  rescue => e
    puts "=== ERROR PATCHING GRPC-CORE basic_seq.h ==="
    puts e.message
    puts e.backtrace.join("\n")
    puts "============================================="
  end
end
