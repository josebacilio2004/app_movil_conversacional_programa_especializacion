platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/FLUTTER_ROOT\=(.*)/)
      return matches[1].strip if matches
    end
  end
  raise "Could not find FLUTTER_ROOT in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  begin
    flutter_post_install(installer)
  rescue => e
    puts "[WARN] flutter_post_install failed: #{e.message}"
  end

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # ============================================================
      # KEY FIX: Add Flutter.framework to search paths so that
      # #import <Flutter/Flutter.h> works with use_frameworks!
      # ============================================================
      fsp = config.build_settings['FRAMEWORK_SEARCH_PATHS'] || ['$(inherited)']
      if fsp.is_a?(String)
        fsp = fsp.split
      end
      flutter_fw_path = '"${PODS_ROOT}/../Flutter"'
      unless fsp.include?(flutter_fw_path)
        fsp << flutter_fw_path
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] = fsp
      end

      # Suppress Xcode 16 C++ template errors in gRPC pods
      if ['BoringSSL-GRPC', 'gRPC-Core', 'gRPC-C++', 'gRPC-C++/Implementation'].include?(target.name)
        cflags = config.build_settings['OTHER_CFLAGS'] || '$(inherited)'
        cppflags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        suppress = '-Wno-error=missing-template-arg-list-after-template-kw'

        config.build_settings['OTHER_CFLAGS'] = "#{cflags} #{suppress}" unless cflags.include?(suppress)
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{cppflags} #{suppress}" unless cppflags.include?(suppress)
      end
    end

    # Remove the unsupported '-G' per-file flag from BoringSSL-GRPC
    if target.name == 'BoringSSL-GRPC' && target.respond_to?(:source_build_phase)
      begin
        target.source_build_phase.files.each do |file|
          if file.settings && file.settings['COMPILER_FLAGS']
            flags = file.settings['COMPILER_FLAGS'].split
            flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' || flag == '-G' }
            file.settings['COMPILER_FLAGS'] = flags.join(' ')
          end
        end
      rescue => e
        puts "[WARN] BoringSSL flag cleanup failed: #{e.message}"
      end
    end
  end
end
